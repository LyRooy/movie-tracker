{
  "name": "movie-tracker",
  "version": "1.0.0",
  "description": "Movie tracking application with Firebase backend or Cloudflare D1",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node firebase-init.js",
    "dev:cloudflare": "wrangler dev",
    "deploy:cloudflare": "wrangler deploy",
    "db:create": "wrangler d1 create movie-tracker-db",
    "db:migrate": "wrangler d1 execute movie-tracker-db --file=./cloudflare/schema.sql",
    "db:migrate:local": "wrangler d1 execute movie-tracker-db --local --file=./cloudflare/schema.sql",
    "db:seed": "wrangler d1 execute movie-tracker-db --file=./cloudflare/seed.sql",
    "db:seed:local": "wrangler d1 execute movie-tracker-db --local --file=./cloudflare/seed.sql"
  },
  "keywords": [
    "movie",
    "tracker",
    "firebase",
    "cloudflare",
    "d1",
    "workers"
  ],
  "author": "LyRooy",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "firebase-admin": "^12.0.0",
    "firebase": "^10.7.1",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "express-rate-limit": "^7.1.5",
    "hono": "^3.11.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "wrangler": "^3.22.1"
  }
}
