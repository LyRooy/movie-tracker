rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Users collection
    match /Users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();
      // Users can only update their own profile
      allow update: if isOwner(userId);
      // Only allow creation during registration (handled by backend)
      allow create: if isAuthenticated();
      // Users can delete their own account or admin can delete
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // Movies collection
    match /Movies/{movieId} {
      // Anyone can read movies (for browsing)
      allow read: if true;
      // Only authenticated users can add movies
      allow create: if isAuthenticated();
      // Only admin or creator can update
      allow update: if isAdmin();
      // Only admin can delete
      allow delete: if isAdmin();
    }
    
    // Watched collection
    match /Watched/{watchedId} {
      // Users can read their own watched entries
      allow read: if isAuthenticated() && 
                     resource.data.user_id == request.auth.uid;
      // Users can create their own watched entries
      allow create: if isAuthenticated() && 
                      request.resource.data.user_id == request.auth.uid;
      // Users can update their own watched entries
      allow update: if isAuthenticated() && 
                      resource.data.user_id == request.auth.uid;
      // Users can delete their own watched entries
      allow delete: if isAuthenticated() && 
                      resource.data.user_id == request.auth.uid;
    }
    
    // Reviews collection
    match /Reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      // Authenticated users can create reviews
      allow create: if isAuthenticated() && 
                      request.resource.data.user_id == request.auth.uid &&
                      request.resource.data.rating >= 1 && 
                      request.resource.data.rating <= 5;
      // Users can update their own reviews
      allow update: if isAuthenticated() && 
                      resource.data.user_id == request.auth.uid;
      // Users can delete their own reviews
      allow delete: if isAuthenticated() && 
                      resource.data.user_id == request.auth.uid;
    }
    
    // Challenges collection
    match /Challenges/{challengeId} {
      // Anyone can read challenges
      allow read: if true;
      // Only authenticated users can create challenges
      allow create: if isAuthenticated();
      // Only admin can update challenges
      allow update: if isAdmin();
      // Only admin can delete challenges
      allow delete: if isAdmin();
    }
    
    // Challenge_Participants collection
    match /Challenge_Participants/{participantId} {
      // Users can read their own participation and all participants of challenges they joined
      allow read: if isAuthenticated();
      // Users can join challenges
      allow create: if isAuthenticated() && 
                      request.resource.data.user_id == request.auth.uid;
      // Users can update their own participation (progress, completion)
      allow update: if isAuthenticated() && 
                      resource.data.user_id == request.auth.uid;
      // Users can leave challenges (delete their participation)
      allow delete: if isAuthenticated() && 
                      resource.data.user_id == request.auth.uid;
    }
    
    // Challenge_Watched collection
    match /Challenge_Watched/{challengeWatchedId} {
      // Users can read their challenge watched entries
      allow read: if isAuthenticated();
      // Users can create challenge watched entries
      allow create: if isAuthenticated();
      // Users can update their challenge watched entries
      allow update: if isAuthenticated();
      // Users can delete their challenge watched entries
      allow delete: if isAuthenticated();
    }
    
    // Badges collection
    match /Badges/{badgeId} {
      // Anyone can read badges
      allow read: if true;
      // Only admin can create badges
      allow create: if isAdmin();
      // Only admin can update badges
      allow update: if isAdmin();
      // Only admin can delete badges
      allow delete: if isAdmin();
    }
    
    // User_Badges collection
    match /User_Badges/{userBadgeId} {
      // Users can read their own badges and others' badges
      allow read: if isAuthenticated();
      // Only backend or admin can award badges
      allow create: if isAdmin();
      // Only admin can update badges
      allow update: if isAdmin();
      // Users can delete their own badges display, admin can delete any
      allow delete: if isAuthenticated() && 
                      (resource.data.user_id == request.auth.uid || isAdmin());
    }
    
    // Friends collection
    match /Friends/{friendshipId} {
      // Users can read friendships they're part of
      allow read: if isAuthenticated() && 
                     (resource.data.user1_id == request.auth.uid || 
                      resource.data.user2_id == request.auth.uid);
      // Users can send friend requests
      allow create: if isAuthenticated() && 
                      request.resource.data.user1_id == request.auth.uid &&
                      request.resource.data.status == 'pending';
      // Users can respond to friend requests sent to them
      allow update: if isAuthenticated() && 
                      resource.data.user2_id == request.auth.uid;
      // Users can delete friendships they're part of
      allow delete: if isAuthenticated() && 
                      (resource.data.user1_id == request.auth.uid || 
                       resource.data.user2_id == request.auth.uid);
    }
  }
}
